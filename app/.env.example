# ── Database ───────────────────────────────────────────────────
DATABASE_URL=./data/mdk.db

# ── Auth ──────────────────────────────────────────────────────
FAN_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ── PayPal ────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENV=sandbox

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@mydigitalkingdom.com

# ── Kimi OAuth ────────────────────────────────────────────────
VITE_KIMI_AUTH_URL=
VITE_APP_ID=
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# ── App ──────────────────────────────────────────────────────
APP_ID=mydigitalkingdom
APP_SECRET=change-me-in-production
NODE_ENV=production
